{
  "name": "chatbot-cap",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9",
    "@cap-js/sqlite": "^2",
    "express": "^4",
    "highlight.js": "^11.11.1",
    "marked": "^16.0.0",
    "openai": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.11.0"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "auth": "mocked"
    }
  },
  "scripts": {
    "start": "cds deploy ./srv/csn.json --to sqlite:db.sqlite && cds serve ./srv/csn.json",
    "watch-chatbot": "cds watch --open chatbot/webapp/index.html?sap-ui-xx-viewCache=false"
  }
}